# ================================================================
# LISA Platform – Environment Variables
# Sao chép file này thành .env và điền vào
#   cp .env.example .env
# KHÔNG commit file .env lên git!
# ================================================================

# ── PostgreSQL ──────────────────────────
POSTGRES_PASSWORD=lisa_secret

# ── GitHub Personal Access Token ────────
# Lấy tại: https://github.com/settings/tokens
# Scope cần: repo (hoặc public_repo nếu public)
GITHUB_TOKEN=ghp_your_token_here
GITHUB_ORG=your-github-org-or-username

# ── GitLab Personal Access Token ────────
# Lấy tại: https://gitlab.com/-/profile/personal_access_tokens
# Scope cần: api
GITLAB_TOKEN=glpat-your_token_here
# Namespace ID: vào GitLab → Group Settings → General → Group ID
GITLAB_NAMESPACE_ID=12345678
