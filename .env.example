# PostgreSQL
POSTGRES_USER=lisa
POSTGRES_PASSWORD=lisa_secret
POSTGRES_PORT=5432
POSTGRES_ADMIN_DB=postgres
CURRICULUM_DB_NAME=lisadb
REALTIME_DB_NAME=realtime_db
USER_PAYMENT_DB_NAME=user_payment_db

# Published ports
CURRICULUM_PORT=8080
REALTIME_PORT=3000
USER_PAYMENT_PORT=5000
FRONTEND_PORT=5173

# Shared JWT across curriculum, realtime, user-payment
JWT_SECRET_KEY=change_me_to_long_random_secret_at_least_32_chars
JWT_ISSUER=ProjectLucy.API
JWT_AUDIENCE=ProjectLucy.Client
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7

# Curriculum service
CURRICULUM_SPRING_CACHE_TYPE=simple
CURRICULUM_REDIS_HOST=localhost
CURRICULUM_REDIS_PORT=6379
CURRICULUM_REDIS_PASSWORD=
REALTIME_SESSION_JOIN_EVENT=session.join
LMS_AUTO_SWITCH_SCAN_INTERVAL_MS=60000
LMS_END_SESSION_ON_LAST_SUBLEVEL=false

# Realtime service
WEB_CLIENT_BASE_URL=http://localhost:5173
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
AGORA_TOKEN_EXPIRE_SECONDS=3600
AGORA_REST_CUSTOMER_ID=
AGORA_REST_CUSTOMER_SECRET=
AGORA_RECORDING_UID=9999
AGORA_RECORDING_MODE=composite
AGORA_RECORDING_STORAGE_VENDOR=
AGORA_RECORDING_STORAGE_CONFIG=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_STREAM_SIGNING_KEY=
CLOUDFLARE_STREAM_SIGNING_KEY_ID=
CLOUDFLARE_STREAM_CUSTOMER_CODE=

# User payment service
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:4200
BASE_CALLBACK_URL=http://localhost:5000
REALTIME_SERVICE_AUTH_POLICY=Default
REALTIME_SERVICE_CLUSTER_ID=realtime-cluster
REALTIME_SERVICE_AGORA_PATH=/api/agora/{**catch-all}
REALTIME_SERVICE_SOCKETIO_PATH=/socket.io/{**catch-all}
SEPAY_URL=https://pay-sandbox.sepay.vn/v1/checkout/init
SEPAY_API_KEY=
SEPAY_MERCHANT_ID=
SEPAY_SECRET_KEY=
SEPAY_IS_SANDBOX=true
SEPAY_SUCCESS_URL=http://localhost:5173/payment/success
SEPAY_ERROR_URL=http://localhost:5173/payment/error
SEPAY_CANCEL_URL=http://localhost:5173/payment/cancel

# Frontend build-time public URLs for browser
FRONTEND_VITE_API_BASE_URL=http://localhost:5000
FRONTEND_VITE_API_URL=http://localhost:5000
FRONTEND_VITE_LMS_API_URL=http://localhost:8080/api/lms
FRONTEND_VITE_REALTIME_URL=http://localhost:3000
